{
  "name": "jexl-extended",
  "version": "2.0.1",
  "description": "Extended grammar for Javascript Expression Language (JEXL)",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "readme": "README.md",
  "engines": {
    "node": ">= 16.0.0"
  },
  "scripts": {
    "test": "vitest",
    "build": "tsc -p tsconfig.release.json",
    "docs:typedoc": "typedoc --json ./docs/typedoc.json --entryPoints ./src/extended-grammar.ts",
    "docs:completion": "tsx ./completion-docs.ts",
    "docs:json": "tsx ./docs.ts",
    "docs:mdx": "tsx ./generate-mdx-docs.ts",
    "docs:mdx:clean": "tsx ./mdx-utils.ts clean",
    "docs:mdx:validate": "tsx ./mdx-utils.ts validate",
    "docs:mdx:stats": "tsx ./mdx-utils.ts stats",
    "docs": "npm run docs:typedoc && npm run docs:completion && npm run build && npm run docs:json && npm run docs:mdx"
  },
  "keywords": [
    "JSON",
    "expression",
    "evaluator",
    "parser",
    "target",
    "context",
    "jexl",
    "filter",
    "selector"
  ],
  "author": "Niko Raes <niko.raes@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/konnektr-io/jexl-extended.git"
  },
  "homepage": "https://docs.konnektr.io/docs/jexl",
  "license": "MIT",
  "peerDependencies": {
    "monaco-editor": ">=0.40.0"
  },
  "peerDependenciesMeta": {
    "monaco-editor": {
      "optional": true
    }
  },
  "dependencies": {
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "jexl": "^2.3.0",
    "uuid": "^14.0.0",
    "windows-iana": "^5.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/jexl": "^2.3.4",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "eslint": "^9.39.4",
    "eslint-plugin-n": "^17.24.0",
    "eslint-plugin-promise": "^7.2.1",
    "globals": "^17.5.0",
    "typedoc": "^0.28.9",
    "tsx": "^4.19.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.44.0",
    "vite": "^8.0.10",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.5"
  }
}